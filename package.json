{
  "name": "kapi-ui",
  "version": "0.2.2",
  "description": "Visually prompt your UI",
  "scripts": {
    "build": "tsc && cp src/browser/overlay.css dist/browser/overlay.css && cp src/browser/comments.css dist/browser/comments.css",
    "dev": "tsc --watch --preserveWatchOutput",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "kapi-ui": "dist/cli/setup.js"
  },
  "exports": {
    "./vite-plugin": "./dist/node/vite-plugin.js",
    "./nuxt": "./dist/node/nuxt-module.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jcebermudo/kapi.git"
  },
  "keywords": [
    "ai",
    "design",
    "frontend"
  ],
  "author": "James Bermudo",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/jcebermudo/kapi/issues"
  },
  "homepage": "https://github.com/jcebermudo/kapi#readme",
  "devDependencies": {
    "@nuxt/schema": "^3.14.0",
    "@types/node": "^26.1.0",
    "@types/ws": "^8.18.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.8",
    "estree-walker": "^2.0.2",
    "magic-string": "^0.30.21",
    "magicast": "^0.5.3",
    "source-map-js": "^1.2.1",
    "ws": "^8.21.0"
  }
}
